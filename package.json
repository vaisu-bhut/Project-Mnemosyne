{
  "name": "mnemosyne",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "infra:up": "docker compose up -d --wait",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "db:reset": "tsx services/db/reset.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "api": "tsx watch services/api/index.ts",
    "worker": "tsx watch services/worker/index.ts"
  },
  "dependencies": {
    "bullmq": "^5.34.5",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "kysely": "^0.27.5",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "^5.11.0"
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
