# ---------------------------------------------------------------------------
# Project Mnemosyne — local development environment
# Copy this file to `.env` and adjust if needed. The defaults match
# docker-compose.yml so `pnpm infra:up && pnpm migrate && pnpm test` just works.
# ---------------------------------------------------------------------------

# --- Postgres (pgvector/pgvector:pg16) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mnemosyne
POSTGRES_PASSWORD=mnemosyne
POSTGRES_DB=mnemosyne
# Connection string used by the app + node-pg-migrate.
DATABASE_URL=postgres://mnemosyne:mnemosyne@localhost:5432/mnemosyne

# Separate database used by the test suite (created automatically by tests).
TEST_DATABASE_URL=postgres://mnemosyne:mnemosyne@localhost:5432/mnemosyne_test

# --- Embeddings ---
# Single source of truth for the embedding vector dimension. Used by both the
# app and the schema. Default 1024 = Qwen text-embedding-v3.
VECTOR_DIM=1024

# Embedding provider: "dev" (deterministic local, no secrets), "gemini", or "qwen".
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
# Required for gemini/qwen. For gemini, use a Google AI Studio key. NEVER commit a real key.
# EMBEDDING_API_KEY=
# Gemini task type hint: RETRIEVAL_DOCUMENT (stored memory) or RETRIEVAL_QUERY (search).
EMBEDDING_TASK_TYPE=RETRIEVAL_DOCUMENT
# Optional base-URL override (defaults: gemini -> generativelanguage.googleapis.com,
# qwen -> dashscope-intl.aliyuncs.com).
# EMBEDDING_BASE_URL=

# --- Generative LLM (extraction + grounded answers + semantic adjudication) ---
# "dev" = offline heuristics (no network); "qwen" = Qwen via DashScope; "gemini".
# Convention here: Gemini does EMBEDDINGS, Qwen does the generative LLM.
LLM_PROVIDER=qwen
# Qwen (DashScope OpenAI-compatible). Separate key from the Gemini one above.
# QWEN_API_KEY=
QWEN_MODEL=qwen-plus
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Only used when LLM_PROVIDER=gemini:
LLM_MODEL=gemini-2.5-flash

# --- Consolidation ("sleep" layer) ---
DECAY_MAX_AGE_DAYS=90               # un-reinforced facts older than this go 'stale'
RETENTION_COMPRESS_AFTER_DAYS=90   # drop raw episode bodies after this (kept in object store)
RETENTION_PURGE_AFTER_DAYS=365     # purge episodes entirely after this
CONSOLIDATE_INTERVAL_MS=86400000   # repeatable consolidation cadence; 0 disables

# --- Semantic intelligence (embedding candidate-gen + LLM adjudication) ---
# true => alias resolution, contradiction detection, and Conductor routing use
# meaning (requires LLM_PROVIDER=gemini); false => fast lexical heuristics.
SEMANTIC_INTELLIGENCE=false
ENTITY_SIM_THRESHOLD=0.84          # cosine sim to make an entity-merge candidate
CONTRADICTION_SIM_THRESHOLD=0.8    # cosine sim to make a contradiction candidate
SEMANTIC_MAX_PAIRS=25              # max LLM-adjudicated pairs per pass

# --- Agents (Phase 3) ---
RELATIONSHIP_STALE_DAYS=30         # no contact this long raises a relationship alert
NUDGER_INTERVAL_MS=0               # repeatable Nudger cadence; 0 disables

# --- Redis (BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Object storage (local filesystem for now) ---
# Raw artifacts (attachments, audio, images) are written under this directory.
# Swap the storage module for S3 later without touching callers.
LOCAL_STORAGE_DIR=./.data/artifacts

# --- Auth (mobile: JWT access token + rotating refresh token) ---
# Generate strong random values in production (e.g. `openssl rand -base64 48`).
JWT_SECRET=dev-insecure-jwt-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
# Key material for encrypting stored OAuth tokens at rest (AES-256-GCM).
TOKEN_ENC_KEY=dev-insecure-token-encryption-key
APP_BASE_URL=http://localhost:3000

# --- Web frontend (CORS + OAuth hand-off) ---
# Comma-separated browser origins allowed to call the API ("*" = any). In dev the
# Next.js app (app/) proxies same-origin, so CORS only matters for production.
# The Google OAuth web hand-off also redirects here: the callback sends the
# browser to <first WEB_ORIGIN>/auth/google/callback#accessToken=…&refreshToken=…
# so this must be a concrete origin (not "*") for the web sign-in flow to work.
WEB_ORIGIN=http://localhost:3001

# --- Google OAuth + Gmail ingest ---
# Create an OAuth 2.0 Client (type: Web) in Google Cloud Console, enable the
# Gmail API, and add the redirect URI below to the client's allowed redirects.
# Note: GOOGLE_REDIRECT_URI points at this *backend* callback (where Google
# sends the code). For the web flow the backend then hands off to the frontend
# at WEB_ORIGIN above — the frontend route is NOT a Google-registered redirect.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GMAIL_QUERY=newer_than:30d        # Gmail search query for ingestion
GMAIL_MAX_MESSAGES=25             # max messages pulled per ingest run
CALENDAR_DAYS_PAST=7              # calendar ingest window (days back)
CALENDAR_DAYS_FUTURE=30           # calendar ingest window (days forward)
CALENDAR_MAX_EVENTS=50            # max events pulled per ingest run
CONTACTS_MAX_RESULTS=200          # max contacts pulled per ingest run (Google + Outlook)
BRIEFING_LOOKAHEAD_HOURS=24       # window for time-triggered pre-meeting briefings

# --- Microsoft OAuth + Outlook ingest ---
# Register an app in Entra ID (Azure AD): add a Web redirect URI matching
# MICROSOFT_REDIRECT_URI, and delegated Microsoft Graph permissions
# Mail.Read, Calendars.Read, Contacts.Read, User.Read, offline_access.
# TENANT: "common" (multi-tenant + personal) or a specific tenant id.
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback
OUTLOOK_MAX_MESSAGES=25           # max Outlook messages pulled per ingest run

# --- Ingestion pacing (respect provider/embedding rate limits) ---
# Ingestion is a paced background job: it delays between items and the worker
# serializes runs so a burst doesn't trip the embedding/API quota. Connectors
# also retry 429/503 with backoff. If you hit a *daily* embedding quota, lower
# GMAIL_MAX_MESSAGES or set EMBEDDING_PROVIDER=qwen (or enable billing).
INGEST_ITEM_DELAY_MS=250          # pause between items in a run
INGEST_CONCURRENCY=1              # ingest jobs in parallel (1 = serialize)
INGEST_MAX_PER_MIN=0             # 0 = off; >0 caps ingest jobs/min (BullMQ limiter)

# --- API server ---
API_HOST=0.0.0.0
API_PORT=3000
