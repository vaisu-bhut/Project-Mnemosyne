# Base URL the browser API client calls. Defaults to the same-origin dev proxy
# (/api -> backend via next.config rewrites). For a cross-origin production
# deployment set this to the API origin, e.g. https://api.example.com
NEXT_PUBLIC_API_BASE_URL=/api

# Where the dev proxy forwards /api/* (the Fastify backend). Server-side only.
BACKEND_ORIGIN=http://localhost:3000
